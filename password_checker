import hashlib
import requests
import sys

if len(sys.argv) > 1:
    password = sys.argv[1]
else: 
    password = input("Enter a password to check: ")
sha1_hash = hashlib.sha1(password.encode()).hexdigest().upper()
print(sha1_hash)

symbols = "!@#$%^&*()_+-=[]{}|;:,.<>?/~"

def check_strength(password):
    score = 0
    if len(password) >= 12:
        print("Password has good length")
        score+=2
    elif len(password) >= 8:
        print("Password has minimum length, consider extending your password length")
        score+=1
    else:
        print("Password too short, make your password longer")
    if any(c.isupper() for c in password):
        print("Password has uppercase")
        score+=1
    else:
        print("Password has no uppercase, try adding a few uppercase letters, in your password")
    if any(c.islower() for c in password):
        print("Password has lowercase")
        score+=1
    else:
        print("Password has no lowercase, try adding a few lowercase letters in your password")
    if any(c.isdigit() for c in password):
        print("Password has digit(s)")
        score+=1
    else:
        print("Password has no digits, try adding a few numbers into your password")
    if any(c in symbols for c in password):
        print("Password has symbol(s)")
        score+=1
    else:
        print("Password has no symbols, try adding a few symbols into your password")
    if score >= 5:
        print("🟢Your password is GREAT!")
    elif score >= 4:
        print("🟢Your password is GOOD!")
    elif score >= 3:
        print("🔴Your password is DECENT — could be better.")
    else:
        print("🔴Your password is WEAK — don't use it!")


